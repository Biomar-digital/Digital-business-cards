# ─────────────────────────────────────────────────────────────
# Digital Business Cards — configuración del backend
# Copia este archivo como `.env` y rellena tus credenciales.
# ─────────────────────────────────────────────────────────────

# Puerto del servidor API
PORT=4000

# Modo de los proveedores externos:
#   mock  -> no llama a ninguna API real, simula respuestas (ideal para desarrollo)
#   live  -> usa AddToWallet + qr-code-generator reales
PROVIDER_MODE=mock

# ── AddToWallet (https://app.addtowallet.co) ──
# API key desde el menú de usuario en app.addtowallet.co
ADDTOWALLET_API_KEY=
ADDTOWALLET_BASE_URL=https://app.addtowallet.co/api
# Plantilla/diseño de pase a usar al crear tarjetas (template id de tu cuenta)
ADDTOWALLET_TEMPLATE_ID=

# ── qr-code-generator (dominio corto qrco.de) ──
# API key de tu plan premium
QRCODE_API_KEY=
QRCODE_BASE_URL=https://api.qr-code-generator.com/v1
# (opcional) dominio corto personalizado; por defecto qrco.de
QRCODE_SHORT_DOMAIN=qrco.de

# ── Email (solo si EMAIL_PROVIDER=smtp) ──
# Por defecto el envío lo hace AddToWallet. Para usar SMTP propio cámbialo aquí.
EMAIL_PROVIDER=addtowallet
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Biomar Digital <no-reply@biomar.digital>"

# ── Seguridad del panel ──
# Token simple para proteger el panel/API (cabecera x-admin-token)
ADMIN_TOKEN=cambia-este-token
