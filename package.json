{
  "name": "digital-business-cards",
  "version": "0.1.0",
  "private": true,
  "description": "Panel de administración que unifica AddToWallet (pases wallet) y qr-code-generator (QR dinámicos) para tarjetas de presentación digitales. Desplegado en Cloudflare Workers + Static Assets + D1.",
  "type": "module",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "npm --workspace web run build",
    "dev:web": "npm --workspace web run dev",
    "dev": "npm run build && wrangler dev",
    "db:init": "wrangler d1 execute dbc --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute dbc --remote --file=./schema.sql",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.3",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
